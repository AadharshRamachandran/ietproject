# Production Environment Variables
# Copy this file to .env.production (NOT committed to git)

# Application
APP_ENV=production
APP_NAME=AetherNet

# Database
MONGODB_URI=<your-mongodb-atlas-uri>
MONGODB_DB_NAME=aethernet

# Authentication
CLERK_FRONTEND_API=<your-clerk-frontend-api>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Storage (Pinata/IPFS)
PINATA_API_KEY=<your-pinata-api-key>
PINATA_API_SECRET=<your-pinata-api-secret>
PINATA_JWT=<your-pinata-jwt>
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# CORS Origins (update with actual Vercel URL)
CORS_ORIGINS=https://your-vercel-domain.vercel.app,https://your-custom-domain.com

# Federated Learning Server
FL_SERVER_HOST=0.0.0.0
FL_SERVER_PORT=8080
FL_ROUNDS=3
FL_CLIENT_CONNECT_HOST=<render-backend-url>

# Frontend URL (for backend to reference)
FRONTEND_URL=https://your-vercel-domain.vercel.app
